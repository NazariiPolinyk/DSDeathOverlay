<Window x:Class="DSDeathOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSDeathOverlay"
        mc:Ignorable="d"
        Title="DSDeathOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        Left="20" Top="20"
        Focusable="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <local:BoolToBrushConverter x:Key="EditModeBrush"
                                    FalseBrush="#80000000"
                                    TrueBrush="#A0202060"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToFontWeightConverter x:Key="ActiveBoldConverter"/>
    </Window.Resources>
    <Border x:Name="RootBorder"
            CornerRadius="6"
            Padding="10,4"
            Background="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EditModeBrush}}"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <StackPanel Orientation="Vertical">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="DeathText"
                           Text="{Binding DisplayText}"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsEditMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                    <Button x:Name="ResetBossesButton"
                            Content="reset"
                            Click="ResetBossesButton_Click"
                            Margin="10,0,0,0"
                            Padding="6,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Consolas"
                            Cursor="Hand"
                            ToolTip="Reset boss counts for current game"
                            VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton"
                            Content="x"
                            Click="CloseButton_Click"
                            Margin="6,0,0,0"
                            Padding="6,0"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="Bold"
                            FontFamily="Consolas"
                            Cursor="Hand"
                            ToolTip="Close (Shift+F9)"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Margin="0,4,0,0"
                          MaxHeight="220"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsBossListExpanded, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding BossRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="{Binding Name}"
                                        Tag="{Binding Id}"
                                        Click="BossRow_Click"
                                        HorizontalContentAlignment="Left"
                                        FontFamily="Consolas"
                                        FontWeight="{Binding IsActive, Converter={StaticResource ActiveBoldConverter}}"
                                        Foreground="White"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="2,0"
                                        Cursor="Hand"
                                        ToolTip="Click in edit mode to make this the active boss"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Count}"
                                           Foreground="White"
                                           FontFamily="Consolas"
                                           FontWeight="{Binding IsActive, Converter={StaticResource ActiveBoldConverter}}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</Window>
